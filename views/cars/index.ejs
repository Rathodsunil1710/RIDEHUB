
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">

<style>
/* ─── Reset / Base ─────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --blue:    #2563eb;
  --blue-dk: #1d4fd7;
  --blue-lt: #eff6ff;
  --ink:     #0f1c3f;
  --muted:   #6b7fa8;
  --border:  #dde3ee;
  --surface: #eef2f7;
  --white:   #ffffff;
  --green:   #16a34a;
  --red:     #dc2626;
  --font-body: 'DM Sans', sans-serif;
  --font-head: 'DM Serif Display', serif;
  --shadow-sm: 0 2px 12px rgba(15,30,70,0.08);
  --shadow:    0 4px 24px rgba(15,30,70,0.11);
  --radius:    12px;
  --radius-lg: 18px;
  --navbar-h:  70px;
}

body { font-family: var(--font-body); background: var(--surface); color: var(--ink); -webkit-font-smoothing: antialiased; }

/* ─── HERO ──────────────────────────────────────────── */
.hero {
  position: relative;
  background: linear-gradient(125deg, #0a1628 0%, #0e2354 40%, #1a4096 75%, #1e52b8 100%);
  display: flex;
  flex-direction: column;
  height: calc(100vh - var(--navbar-h));
  min-height: 480px;
  max-height: 680px;
  padding: 0 6%;
  overflow: hidden;
}

.hero-main {
  display: flex;
  align-items: center;
  flex: 1;
  position: relative;
  z-index: 2;
}

/* grid overlay */
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 52px 52px;
  pointer-events: none; z-index: 0;
}

/* right glow */
.hero::after {
  content: '';
  position: absolute;
  width: 700px; height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(30,80,180,0.35) 0%, transparent 65%);
  top: -150px; right: -50px;
  pointer-events: none; z-index: 0;
}

.hero-content {
  position: relative; z-index: 2;
  flex: 0 0 44%;
  max-width: 44%;
  padding-top: 8px;
  animation: fadeUp 0.65s ease both;
}

@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(15,30,70,0.55);
  border: 1px solid rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.75);
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 7px 15px; border-radius: 30px;
  margin-bottom: 20px;
  backdrop-filter: blur(6px);
}
.hero-eyebrow i { font-size: 0.76rem; opacity: 0.9; }

.hero-title {
  font-family: var(--font-head);
  font-size: clamp(2.8rem, 4.8vw, 4.4rem);
  font-weight: 400;
  color: #ffffff;
  line-height: 1.12;
  margin-bottom: 14px;
  letter-spacing: -0.01em;
}
.hero-title span { color: #5aaeff; font-style: italic; }

.hero-subtitle {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
  max-width: 360px;
  margin-bottom: 28px;
  font-weight: 400;
}

.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

.hero-btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--blue);
  color: #fff;
  padding: 13px 26px;
  border-radius: 10px;
  font-size: 0.88rem; font-weight: 700;
  text-decoration: none;
  transition: background 0.18s, transform 0.15s, box-shadow 0.18s;
  box-shadow: 0 4px 20px rgba(37,99,235,0.45);
  font-family: var(--font-body);
  letter-spacing: 0.01em;
}
.hero-btn-primary:hover { background: var(--blue-dk); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,99,235,0.5); color: #fff; }

.hero-btn-ghost {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,0.06);
  border: 1.5px solid rgba(255,255,255,0.22);
  color: rgba(255,255,255,0.8);
  padding: 12px 22px;
  border-radius: 10px;
  font-size: 0.88rem; font-weight: 600;
  text-decoration: none;
  transition: background 0.18s, border-color 0.18s, color 0.18s;
  font-family: var(--font-body);
}
.hero-btn-ghost:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.4); color: #fff; }

.hero-image-wrap {
  position: absolute;
  right: -2%;
  top: 68%;
  transform: translateY(-50%);
  width: 60%;
  z-index: 1;
  animation: carSlide 0.95s cubic-bezier(0.22,1,0.36,1) both;
  animation-delay: 0.15s;
  pointer-events: none;
}

@keyframes carSlide {
  from { opacity: 0; transform: translateY(-50%) translateX(50px); }
  to   { opacity: 1; transform: translateY(-50%) translateX(0); }
}

.hero-image-wrap img {
  width: 100%;
  display: block;
  filter: drop-shadow(0 24px 64px rgba(0,0,0,0.5));
}

/* scroll hint */
.hero-scroll-hint {
  position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
  z-index: 5;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  color: rgba(255,255,255,0.28); font-size: 0.66rem; letter-spacing: 0.1em;
  text-transform: uppercase; font-weight: 600;
  animation: bounce 2.2s ease infinite;
}
@keyframes bounce {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50%      { transform: translateX(-50%) translateY(6px); }
}
.hero-scroll-hint i { font-size: 0.95rem; }

/* ─── STATS ─────────────────────────────────────────── */
.stats-section {
  background: var(--white);
  padding: 44px 5%;
  border-bottom: 1px solid var(--border);
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.stat-item {
  background: var(--white);
  padding: 28px 24px;
  display: flex; align-items: center; gap: 16px;
  transition: background 0.18s;
}
.stat-item:hover { background: var(--blue-lt); }
.stat-icon-wrap {
  width: 48px; height: 48px; flex-shrink: 0;
  border-radius: 12px;
  background: var(--blue-lt);
  border: 1px solid #bfdbfe;
  display: flex; align-items: center; justify-content: center;
  color: var(--blue); font-size: 1.2rem;
}
.stat-num {
  font-family: var(--font-body);
  font-size: 1.8rem; font-weight: 800; color: var(--ink);
  line-height: 1; letter-spacing: -0.02em;
}
.stat-label { font-size: 0.8rem; color: var(--muted); margin-top: 4px; font-weight: 500; }

/* ─── SECTION HEADINGS ───────────────────────────────── */
.section-eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  background: var(--blue-lt); color: var(--blue);
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 5px 12px; border-radius: 20px;
  margin-bottom: 10px;
  font-family: var(--font-body);
}
.section-title {
  font-family: var(--font-head);
  font-size: clamp(1.6rem, 3vw, 2.1rem);
  font-weight: 400; color: var(--ink);
  margin-bottom: 6px; line-height: 1.2;
}
.section-sub { font-size: 0.86rem; color: var(--muted); line-height: 1.6; font-weight: 400; }

/* ─── CARS LISTING AREA ──────────────────────────────── */
.listing-section { padding: 52px 5%; }
.listing-section-head {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 26px; flex-wrap: wrap; gap: 12px;
}
.listing-layout { display: flex; gap: 22px; align-items: flex-start; }

/* Sidebar */
.filter-sidebar {
  width: 236px; flex-shrink: 0;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 18px;
  position: sticky; top: 90px;
}
.filter-sidebar-title {
  font-size: 0.78rem; font-weight: 700; color: var(--ink);
  text-transform: uppercase; letter-spacing: 0.08em;
  margin-bottom: 16px;
  display: flex; align-items: center; gap: 7px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.filter-sidebar-title i { color: var(--blue); }

/* Flat filter groups — always visible, no accordion */
.filter-group { margin-bottom: 14px; }
.filter-group-label {
  font-size: 0.74rem; font-weight: 700; color: var(--ink);
  margin-bottom: 7px;
  display: flex; align-items: center; gap: 6px;
}
.filter-group-label i { color: var(--blue); font-size: 0.74rem; }

.range-inputs { display: flex; align-items: center; gap: 6px; }
.range-inputs input {
  flex: 1; padding: 8px 10px;
  border: 1.5px solid var(--border); border-radius: 8px;
  font-size: 0.8rem; font-family: var(--font-body); color: var(--ink);
  outline: none; transition: border-color 0.18s;
  -webkit-appearance: none; appearance: none;
  background: var(--white);
}
.range-inputs input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,0.08); }
.range-separator { font-size: 0.72rem; color: var(--muted); flex-shrink: 0; }

.filter-select-wrap { position: relative; }
.filter-select-icon {
  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
  color: var(--muted); font-size: 0.72rem; pointer-events: none;
}
.filter-select {
  width: 100%; padding: 8px 30px 8px 10px;
  border: 1.5px solid var(--border); border-radius: 8px;
  font-size: 0.8rem; font-family: var(--font-body); color: var(--ink);
  background: var(--white); outline: none;
  transition: border-color 0.18s;
  -webkit-appearance: none; appearance: none;
  cursor: pointer;
}
.filter-select:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,0.08); }

.filter-actions { display: flex; flex-direction: column; gap: 7px; margin-top: 14px; }
.filter-btn {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  padding: 9px 14px; border-radius: 9px;
  font-size: 0.8rem; font-weight: 700; font-family: var(--font-body);
  cursor: pointer; text-decoration: none; transition: all 0.18s; border: none;
}
.filter-btn-primary { background: var(--blue); color: #fff; }
.filter-btn-primary:hover { background: var(--blue-dk); transform: translateY(-1px); color: #fff; }
.filter-btn-secondary {
  background: var(--surface); color: var(--muted);
  border: 1.5px solid var(--border);
}
.filter-btn-secondary:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-lt); }

.filter-results-count {
  text-align: center; margin-top: 12px;
  font-size: 0.74rem; color: var(--muted);
  background: var(--surface); border-radius: 7px;
  padding: 6px;
  font-family: var(--font-body);
}
.filter-results-count strong { color: var(--blue); }

/* Mobile filter toggle */
.filter-toggle-btn {
  display: none; align-items: center; gap: 8px;
  background: var(--white); border: 1.5px solid var(--border);
  border-radius: 9px; padding: 9px 16px;
  font-size: 0.84rem; font-weight: 600; font-family: var(--font-body);
  color: var(--ink); cursor: pointer; margin-bottom: 14px;
  transition: border-color 0.18s;
}
.filter-toggle-btn:hover { border-color: var(--blue); color: var(--blue); }
.filter-badge {
  background: var(--blue); color: #fff;
  font-size: 0.66rem; font-weight: 700;
  padding: 2px 7px; border-radius: 10px;
}

/* Cars grid */
.cars-grid-container { flex: 1; min-width: 0; }
.cars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* Car Card */
.car-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform 0.22s, box-shadow 0.22s;
  display: flex; flex-direction: column;
}
.car-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }

.car-card-img {
  width: 100%; aspect-ratio: 16/10;
  object-fit: cover; display: block;
  background: var(--surface);
}

.car-card-body { padding: 14px 16px; flex: 1; display: flex; flex-direction: column; gap: 8px; }

.car-card-title {
  font-size: 0.92rem; font-weight: 700; color: var(--ink);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  line-height: 1.3;
}

.car-card-price {
  font-size: 1.1rem; font-weight: 800; color: var(--blue);
  letter-spacing: -0.01em;
}

.car-card-location {
  display: flex; align-items: center; gap: 5px;
  font-size: 0.76rem; color: var(--muted);
}
.car-card-location i { color: var(--red); font-size: 0.76rem; }

.car-card-specs { display: flex; gap: 5px; flex-wrap: wrap; }
.spec-pill {
  display: inline-flex; align-items: center; gap: 4px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 6px; padding: 3px 8px;
  font-size: 0.7rem; font-weight: 600; color: var(--muted);
}
.spec-pill i { font-size: 0.68rem; color: var(--blue); }

.car-card-btn {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  background: var(--blue-lt); color: var(--blue);
  border: 1.5px solid #bfdbfe;
  border-radius: 9px; padding: 9px;
  font-size: 0.8rem; font-weight: 700; text-decoration: none;
  margin-top: auto;
  transition: background 0.18s, border-color 0.18s, color 0.18s;
  font-family: var(--font-body);
}
.car-card-btn:hover { background: var(--blue); color: #fff; border-color: var(--blue); }

/* No cars state */
.no-cars {
  grid-column: 1/-1;
  text-align: center; padding: 56px 24px;
  background: var(--white); border-radius: var(--radius-lg);
  border: 1px solid var(--border);
}
.no-cars i { font-size: 2.5rem; color: var(--border); display: block; margin-bottom: 12px; }
.no-cars p { color: var(--muted); font-size: 0.9rem; margin-bottom: 14px; }
.no-cars a { color: var(--blue); font-weight: 600; text-decoration: none; }
.no-cars a:hover { text-decoration: underline; }

/* ─── SERVICES ───────────────────────────────────────── */
.services-section {
  background: var(--white);
  border-top: 1px solid var(--border);
  padding: 60px 5%;
}
.services-head { margin-bottom: 32px; }
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.service-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 26px 22px;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  cursor: pointer;
}
.service-card:hover {
  border-color: var(--blue);
  box-shadow: 0 6px 28px rgba(37,99,235,0.11);
  transform: translateY(-3px);
}
.service-icon {
  width: 46px; height: 46px;
  border-radius: 12px;
  background: var(--blue-lt);
  border: 1px solid #bfdbfe;
  display: flex; align-items: center; justify-content: center;
  color: var(--blue); font-size: 1.2rem;
  margin-bottom: 14px;
}
.service-card h4 { font-size: 0.92rem; font-weight: 700; color: var(--ink); margin-bottom: 6px; font-family: var(--font-body); }
.service-card p { font-size: 0.8rem; color: var(--muted); line-height: 1.6; margin-bottom: 14px; }
.service-link {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 0.78rem; font-weight: 700; color: var(--blue);
  text-decoration: none; font-family: var(--font-body);
}
.service-link i { font-size: 0.72rem; transition: transform 0.18s; }
.service-card:hover .service-link i { transform: translateX(3px); }

/* ─── RESPONSIVE ─────────────────────────────────────── */
@media (max-width: 1024px) {
  .hero-image-wrap { width: 56%; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .cars-grid { grid-template-columns: repeat(2, 1fr); }
  .services-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .hero { height: auto; min-height: calc(100vh - var(--navbar-h)); max-height: none; padding: 36px 6% 28px; }
  .hero-main { flex-direction: column; align-items: flex-start; gap: 20px; }
  .hero-content { max-width: 100%; flex: none; }
  .hero-image-wrap { position: relative; width: 100%; right: auto; bottom: auto; }
  .listing-layout { flex-direction: column; }
  .filter-sidebar { width: 100%; position: static; display: none; }
  .filter-sidebar.open { display: block; }
  .filter-toggle-btn { display: flex; }
  .cars-grid { grid-template-columns: 1fr 1fr; }
  .services-grid { grid-template-columns: repeat(2, 1fr); }
  .hero-scroll-hint { display: none; }
}
@media (max-width: 480px) {
  .cars-grid { grid-template-columns: 1fr; }
  .services-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: 1fr; }
}
</style>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero">
  <div class="hero-main">
    <div class="hero-content">
      <div class="hero-eyebrow"><i class="bi bi-car-front-fill"></i> India's Trusted Car Marketplace</div>
      <h1 class="hero-title">Find Your <span>Perfect</span><br>Car Today</h1>
      <p class="hero-subtitle">Browse thousands of verified used cars. Filter by price, year, fuel type and more — find the right car near you.</p>
      <div class="hero-actions">
        <a href="/cars" class="hero-btn-primary"><i class="bi bi-search"></i> Browse Cars</a>
        <a href="/cars/new" class="hero-btn-ghost"><i class="bi bi-plus-circle"></i> Sell Your Car</a>
      </div>
    </div>

    <div class="hero-image-wrap">
      <img src="/images/hero-car.png" alt="Cars" />
    </div>
  </div>

  <div class="hero-scroll-hint">
    <i class="bi bi-chevron-double-down"></i>
    scroll
  </div>
</section>

<!-- ═══════════════ STATS ═══════════════ -->
<section class="stats-section">
  <div class="stats-grid">
    <div class="stat-item">
      <div class="stat-icon-wrap"><i class="bi bi-house-fill"></i></div>
      <div>
        <div class="stat-num" data-target="0">0</div>
        <div class="stat-label">Branches Across India</div>
      </div>
    </div>
    <div class="stat-item">
      <div class="stat-icon-wrap"><i class="bi bi-car-front-fill"></i></div>
      <div>
        <div class="stat-num" data-target="0">0</div>
        <div class="stat-label">Cars Sold</div>
      </div>
    </div>
    <div class="stat-item">
      <div class="stat-icon-wrap"><i class="bi bi-people-fill"></i></div>
      <div>
        <div class="stat-num" data-target="0">0</div>
        <div class="stat-label">Happy Clients</div>
      </div>
    </div>
    <div class="stat-item">
      <div class="stat-icon-wrap"><i class="bi bi-stars"></i></div>
      <div>
        <div class="stat-num" data-target="0">0</div>
        <div class="stat-label">New Listings</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ CARS LISTING ═══════════════ -->
<section class="listing-section">
  <div class="listing-section-head">
    <div>
      <div class="section-eyebrow"><i class="bi bi-car-front"></i> Browse Inventory</div>
      <h2 class="section-title">Available Cars</h2>
    </div>
  </div>

  <div class="listing-layout">
    <!-- FILTER SIDEBAR -->
    <aside class="filter-sidebar" id="filterSidebar">
      <div class="filter-sidebar-title"><i class="bi bi-funnel-fill"></i> Filters</div>

      <form id="filterForm" method="GET" action="/cars">

        <!-- Price Range -->
        <div class="filter-group">
          <div class="filter-group-label"><i class="bi bi-currency-rupee"></i> Price Range (₹)</div>
          <div class="range-inputs">
            <input type="number" name="minPrice" placeholder="Min" value="<%= filters.minPrice || '' %>" />
            <span class="range-separator">—</span>
            <input type="number" name="maxPrice" placeholder="Max" value="<%= filters.maxPrice || '' %>" />
          </div>
        </div>

        <!-- Year Range -->
        <div class="filter-group">
          <div class="filter-group-label"><i class="bi bi-calendar3"></i> Year Range</div>
          <div class="range-inputs">
            <input type="number" name="minYear" placeholder="From" value="<%= filters.minYear || '' %>" />
            <span class="range-separator">—</span>
            <input type="number" name="maxYear" placeholder="To" value="<%= filters.maxYear || '' %>" />
          </div>
        </div>

        <!-- Fuel Type -->
        <div class="filter-group">
          <div class="filter-group-label"><i class="bi bi-fuel-pump"></i> Fuel Type</div>
          <div class="filter-select-wrap">
            <select name="fuel" class="filter-select">
              <option value="">All Fuel Types</option>
              <% if (typeof filterOptions !== 'undefined' && filterOptions.fuels) { %>
              <% filterOptions.fuels.forEach(f => { %>
              <option value="<%= f %>" <%= filters.fuel === f ? 'selected' : '' %>><%= f %></option>
              <% }); %><% } %>
            </select>
            <i class="bi bi-chevron-down filter-select-icon"></i>
          </div>
        </div>

        <!-- Transmission -->
        <div class="filter-group">
          <div class="filter-group-label"><i class="bi bi-gear"></i> Transmission</div>
          <div class="filter-select-wrap">
            <select name="transmission" class="filter-select">
              <option value="">All Types</option>
              <% if (typeof filterOptions !== 'undefined' && filterOptions.transmissions) { %>
              <% filterOptions.transmissions.forEach(t => { %>
              <option value="<%= t %>" <%= filters.transmission === t ? 'selected' : '' %>><%= t %></option>
              <% }); %><% } %>
            </select>
            <i class="bi bi-chevron-down filter-select-icon"></i>
          </div>
        </div>

        <!-- City -->
        <div class="filter-group">
          <div class="filter-group-label"><i class="bi bi-geo-alt"></i> City</div>
          <div class="filter-select-wrap">
            <select name="city" class="filter-select">
              <option value="">All Cities</option>
              <% if (typeof filterOptions !== 'undefined' && filterOptions.cities) { %>
              <% filterOptions.cities.forEach(c => { %>
              <option value="<%= c %>" <%= filters.city === c ? 'selected' : '' %>><%= c %></option>
              <% }); %><% } %>
            </select>
            <i class="bi bi-chevron-down filter-select-icon"></i>
          </div>
        </div>

        <!-- State -->
        <div class="filter-group">
          <div class="filter-group-label"><i class="bi bi-map"></i> State</div>
          <div class="filter-select-wrap">
            <select name="state" class="filter-select">
              <option value="">All States</option>
              <% if (typeof filterOptions !== 'undefined' && filterOptions.states) { %>
              <% filterOptions.states.forEach(s => { %>
              <option value="<%= s %>" <%= filters.state === s ? 'selected' : '' %>><%= s %></option>
              <% }); %><% } %>
            </select>
            <i class="bi bi-chevron-down filter-select-icon"></i>
          </div>
        </div>

        <% if (filters.search) { %><input type="hidden" name="search" value="<%= filters.search %>" /><% } %>

        <div class="filter-actions">
          <button type="submit" class="filter-btn filter-btn-primary"><i class="bi bi-search"></i> Apply Filters</button>
          <a href="/cars" class="filter-btn filter-btn-secondary"><i class="bi bi-arrow-clockwise"></i> Reset</a>
        </div>

        <div class="filter-results-count"><strong><%= cars.length %></strong> car<%= cars.length !== 1 ? 's' : '' %> found</div>
      </form>
    </aside>

    <!-- CARS GRID -->
    <div class="cars-grid-container">
      <button class="filter-toggle-btn" id="filterToggleBtn">
        <i class="bi bi-funnel"></i> Filters
        <% if (cars.length > 0) { %><span class="filter-badge"><%= cars.length %></span><% } %>
      </button>

      <div class="cars-grid">
        <% if (cars.length === 0) { %>
        <div class="no-cars">
          <i class="bi bi-inbox"></i>
          <p>No cars found matching your filters.</p>
          <a href="/cars">Clear all filters</a>
        </div>
        <% } else { %>
        <% for (let car of cars) { %>
        <%
          const cardImages = (car.images && car.images.length
            ? car.images
            : (car.image && car.image !== '' ? [car.image] : []));
          const cardImgSrc = cardImages.length
            ? cardImages[0]
            : 'https://via.placeholder.com/400x250?text=No+Image';
        %>
        <div class="car-card">
          <img src="<%= cardImgSrc %>" class="car-card-img" alt="<%= car.carName %>" />
          <div class="car-card-body">
            <div class="car-card-title" title="<%= car.carName %>"><%= car.carName %></div>
            <div class="car-card-price">₹ <%= car.price.toLocaleString('en-IN') %></div>
            <div class="car-card-location">
              <i class="bi bi-geo-alt-fill"></i>
              <span><%= car.city %>, <%= car.state %></span>
            </div>
            <% if (car.year) { %>
            <div class="car-card-specs">
              <span class="spec-pill"><i class="bi bi-calendar3"></i> <%= car.year %></span>
              <span class="spec-pill"><i class="bi bi-fuel-pump"></i> <%= car.fuel || 'N/A' %></span>
              <span class="spec-pill"><i class="bi bi-gear"></i> <%= car.transmission || 'N/A' %></span>
            </div>
            <% } %>
            <a href="/cars/<%= car._id %>" class="car-card-btn"><i class="bi bi-eye"></i> View Details</a>
          </div>
        </div>
        <% } %>
        <% } %>
      </div>
    </div>
  </div>
</section>

