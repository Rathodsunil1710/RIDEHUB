<div class="form-page edit-car-page">
  <div class="form-overlay"></div>

  <div class="form-card">
    <h2 class="form-title">Edit Car Details</h2>
    <p class="form-subtitle">Update your car information carefully</p>

    <form action="/cars/<%= car._id %>?_method=PUT" method="POST">
      
      <div class="form-group">
        <label>Car Name</label>
        <input
          type="text"
          name="car[carName]"
          value="<%= car.carName %>"
          required
        />
      </div>

      <div class="form-group">
        <label>Price (₹)</label>
        <input
          type="number"
          name="car[price]"
          value="<%= car.price %>"
          required
        />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>City</label>
          <input
            type="text"
            name="car[city]"
            value="<%= car.city %>"
          />
        </div>

        <div class="form-group">
          <label>State</label>
          <input
            type="text"
            name="car[state]"
            value="<%= car.state %>"
          />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Year</label>
          <input
            type="number"
            name="car[year]"
            value="<%= car.year %>"
          />
        </div>

        <div class="form-group">
          <label>Fuel</label>
          <input
            type="text"
            name="car[fuel]"
            value="<%= car.fuel %>"
          />
        </div>

        <div class="form-group">
          <label>Transmission</label>
          <input
            type="text"
            name="car[transmission]"
            value="<%= car.transmission %>"
          />
        </div>
      </div>

      <div class="form-group">
        <label>Photo URLs (one per line)</label>
        <textarea
          name="car[images]"
          rows="3"
          placeholder="https://example.com/car-front.jpg&#10;https://example.com/car-side.jpg"
        ><%= (car.images && car.images.length ? car.images.join('\n') : (car.image || '')) %></textarea>
      </div>

      <div class="form-group">
        <label>Description</label>
        <textarea name="car[description]" rows="3"><%= car.description %></textarea>
      </div>

      <button class="form-btn">Update Car</button>
    </form>
  </div>
</div>
